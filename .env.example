# Frontend (Vite) config
# This value is baked into the static build.
# Do NOT put secrets here.
#
# API base URL override.
# Leave this empty for local visual work so dev requests use the Vite proxy
# and avoid browser CORS restrictions.
# If unset:
# - dev uses relative "/api" through Vite's proxy
# - production uses hardcoded https://zajky.zentrobot.io
VITE_API_BASE_URL=

# Local dev proxy target used only by Vite dev server.
# Use the live backend for production-like content while coding locally.
VITE_DEV_API_PROXY_TARGET=https://zajky.zentrobot.io
